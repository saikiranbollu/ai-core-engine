# ==========================================================================
#  AI-Core-Engine – Secret / Credential TEMPLATE
#  Copy this file to .env and fill in the real values.
#  WARNING: DO NOT COMMIT the .env file – it is listed in env/.gitignore
# ==========================================================================

# ---------------------------------------------------------------------------
# Neo4j (local graph database for Knowledge Graph)
# ---------------------------------------------------------------------------
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your-neo4j-password>

# ---------------------------------------------------------------------------
# Jama REST API (requirement management system)
# ---------------------------------------------------------------------------
JAMA_BASE_URL=https://rqmprod.intra.infineon.com
JAMA_API_KEY=<your-jama-api-key>
JAMA_API_SECRET=<your-jama-api-secret>

# ---------------------------------------------------------------------------
# Qdrant (remote vector store for RAG collections)
# ---------------------------------------------------------------------------
QDRANT_API_KEY=<your-qdrant-api-key>

# ---------------------------------------------------------------------------
# LLM Token (for PDF-to-Markdown conversion via gpt4ifx)
# Obtained by running: python token_manager.py
# ---------------------------------------------------------------------------
LLAMA_TOKEN=<auto-populated-by-token-manager>

# ---------------------------------------------------------------------------
# Infineon credentials (used by token_manager.py for Basic auth)
# ---------------------------------------------------------------------------
IFX_USERNAME=<your-infineon-username>
IFX_PASSWORD=<your-infineon-password>

# ---------------------------------------------------------------------------
# Polarion (Bearer JWT) – optional, for future use
# ---------------------------------------------------------------------------
# PolarionAccessToken=<your-jwt-token-here>
