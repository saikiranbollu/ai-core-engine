{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Active DAs",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(count by (da_name) (aice_tool_requests_total))",
          "legendFormat": "active DAs",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "Tool Calls by DA (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(aice_tool_requests_total{da_name=~\"$da_name\"}[5m])) by (da_name)",
          "legendFormat": "{{ da_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }, "overrides": [] }
    },
    {
      "title": "Error Rate by DA",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(aice_tool_requests_total{status=\"error\", da_name=~\"$da_name\"}[5m])) by (da_name)",
          "legendFormat": "{{ da_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "title": "Tool Latency p95 by DA",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(aice_tool_request_duration_seconds_bucket{da_name=~\"$da_name\"}[5m])) by (le, da_name))",
          "legendFormat": "{{ da_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "title": "Top Tools by DA (req/s)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "topk(15, sum(rate(aice_tool_requests_total{da_name=~\"$da_name\"}[5m])) by (da_name, tool))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "title": "Review Gate Routing (AUTO / QUICK / FULL)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum(aice_review_routing_total) by (route)",
          "legendFormat": "{{ route }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "RLM Requests by Task Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(aice_rlm_requests_total[5m])) by (task_type)",
          "legendFormat": "{{ task_type }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "title": "Session Outcomes by DA (F-P5-M01)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum(rate(aice_da_session_outcomes_total{da_name=~\"$da_name\"}[15m])) by (da_name, outcome)",
          "legendFormat": "{{ da_name }} / {{ outcome }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "Session Duration p95 by DA",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(aice_da_session_duration_seconds_bucket{da_name=~\"$da_name\"}[5m])) by (le, da_name))",
          "legendFormat": "{{ da_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "title": "Context Tokens p95 by DA",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(aice_da_context_assembly_tokens_bucket{da_name=~\"$da_name\"}[5m])) by (le, da_name))",
          "legendFormat": "{{ da_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "First-Result Latency p50 by DA",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 30 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(aice_da_first_result_latency_seconds_bucket{da_name=~\"$da_name\"}[5m])) by (le, da_name))",
          "legendFormat": "{{ da_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "title": "LLM Tokens by DA (tok/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 30 },
      "targets": [
        {
          "expr": "sum(rate(aice_da_session_llm_tokens_total{da_name=~\"$da_name\"}[5m])) by (da_name)",
          "legendFormat": "{{ da_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "Pattern Hits by DA (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "targets": [
        {
          "expr": "sum(rate(aice_da_pattern_hits_total{da_name=~\"$da_name\"}[15m])) by (da_name)",
          "legendFormat": "{{ da_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "Tool Calls by Tier (F-P5-M01)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "targets": [
        {
          "expr": "sum(rate(aice_tool_requests_total{da_name=~\"$da_name\"}[5m])) by (tier)",
          "legendFormat": "{{ tier }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    }
  ],
  "schemaVersion": 39,
  "tags": ["aice", "mcp", "da", "productivity"],
  "templating": { "list": [{ "name": "da_name", "label": "DA Name", "type": "query", "query": "label_values(aice_tool_requests_total, da_name)", "datasource": { "type": "prometheus" }, "includeAll": true, "allValue": ".*", "current": { "text": "All", "value": "$__all" }, "refresh": 2, "multi": true, "sort": 1 }] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AI Core Engine — DA Productivity",
  "uid": "aice-da-productivity",
  "version": 1
}
